# ================================================================
# MS2 ms-academic — Variables de entorno
# Copia este archivo a .env y edita los valores
# ================================================================

# ── MySQL ────────────────────────────────────────────────────────
DB_ROOT_PASS=root_utec_2025
DB_NAME=academic_db
DB_USER=utec_user
DB_PASS=utec_pass_2025

# ── Conexión al MS1 (microservicio_auth) ─────────────────────────
#
# OPCIÓN A — MS1 corriendo en Docker en tu misma laptop:
MS1_URL=http://host.docker.internal:3001
#
# OPCIÓN B — MS1 y MS2 en el mismo docker-compose (producción):
# MS1_URL=http://utec_ms_users:3001
#
# OPCIÓN C — Probar MS2 SIN necesitar MS1 (mock):
# MS1_URL=http://localhost:3001
# MS1_MOCK=true

# Si MS1_MOCK=true → no llama al MS1, usa datos ficticios de profesores
MS1_MOCK=false

# ── JWT Secret del MS1 ───────────────────────────────────────────
# DEBE ser EXACTAMENTE el mismo valor que JWT_SECRET en el .env del MS1
# En tu MS1: JWT_SECRET=utec_rate_secret_dev_2025
MS1_JWT_SECRET=utec_rate_secret_dev_2025

# ── Spring ───────────────────────────────────────────────────────
SPRING_PROFILE=dev
SERVER_PORT=3002
