# ── MySQL ─────────────────────────────────────────────────────
DB_ROOT_PASS=root_utec_2025          # password del root (solo para init)
DB_NAME=academic_db
DB_USER=utec_user
DB_PASS=utec_pass_2025               # cambia en producción

# ── MS1 URL ───────────────────────────────────────────────────
# Local (cuando MS1 corre en tu laptop fuera de Docker):
MS1_URL=http://host.docker.internal:3001
MS1_MOCK=true
# Producción (cuando todo está en Docker):
# MS1_URL=http://ms-users:3001

# ── Spring ────────────────────────────────────────────────────
SPRING_PROFILE=dev                   # dev | prod

# ── Puerto ────────────────────────────────────────────────────
SERVER_PORT=3002
